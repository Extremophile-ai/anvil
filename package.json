{
  "name": "anvil",
  "version": "0.0.0",
  "private": true,
  "description": "Anvil — an autonomous, self-healing, self-learning coding harness.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "pnpm build && node smoke/smoke.mjs",
    "smoke:live": "pnpm build && node smoke/live.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.14.0",
    "vitest": "^2.1.5"
  }
}
